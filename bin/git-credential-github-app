#!/usr/bin/env bash
# Git credential helper that mints (and caches) a GitHub App installation token.
#
# Activates only when the decrypted private key is present in /dev/shm.
# Exits 0 with no output otherwise, so git falls through to the next helper
# in the chain (e.g. `gh auth git-credential` for personal access).
set -euo pipefail

CONFIG_FILE="${GH_AGENT_AUTH_CONFIG:-$HOME/.config/gh-agent-auth/config}"
[[ -f "$CONFIG_FILE" ]] && . "$CONFIG_FILE"

KEY_PATH="${GH_AGENT_AUTH_KEY_DECRYPTED:-/dev/shm/github-app-private-key.pem}"
TOKEN_PATH="${GH_AGENT_AUTH_TOKEN_PATH:-/dev/shm/github-app-token}"
EXPIRY_PATH="${GH_AGENT_AUTH_EXPIRY_PATH:-/dev/shm/github-app-token-expiry}"

case "${1:-}" in
  get)
    [[ -f "$KEY_PATH" ]] || exit 0   # fall through to next helper

    now=$(date +%s)
    expiry=$(cat "$EXPIRY_PATH" 2>/dev/null || echo 0)

    if [[ ! -f "$TOKEN_PATH" ]] || (( now >= expiry - 60 )); then
      token=$(get-github-token) || exit 1
      printf '%s' "$token" > "$TOKEN_PATH"
      chmod 600 "$TOKEN_PATH"
      printf '%d' "$(( now + 3600 ))" > "$EXPIRY_PATH"
    fi

    echo "username=x-access-token"
    echo "password=$(cat "$TOKEN_PATH")"
    ;;
  store|erase)
    : # tokens are ephemeral; nothing to persist or revoke
    ;;
esac
